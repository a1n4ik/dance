+$id = (int) ($_GET['id'] ?? 0);
+
+if ($id > 0) {
+    try {
+        // Удаляем файл изображения, если он есть
+        $stmt = $pdo->prepare("SELECT image FROM news WHERE id = ?");
+        $stmt->execute([$id]);
+        $image = $stmt->fetchColumn();
