<?php
session_start();
require_once '../config/database.php';

if (!isset($_SESSION['admin_id'])) {
    header('Location: login.php');
    exit;
}

$error = '';
$success = '';

// Обработка действий
if ($_SERVER['REQUEST_METHOD'] == 'POST') {
    if (isset($_POST['action'])) {
        switch ($_POST['action']) {
            case 'add_schedule':
                $branch = $_POST['branch'];
                $class_type = $_POST['class_type'];
                $day_of_week = $_POST['day_of_week'];
                $start_time = $_POST['start_time'];
                $class_name = $_POST['class_name'];
                $teacher = $_POST['teacher'];
                $status = $_POST['status'];
                
                try {
                    $stmt = $pdo->prepare("INSERT INTO schedule (branch, class_type, day_of_week, start_time, class_name, teacher, status) VALUES (?, ?, ?, ?, ?, ?, ?)");
                    $stmt->execute([$branch, $class_type, $day_of_week, $start_time, $class_name, $teacher, $status]);
                    $success = "Занятие успешно добавлено в расписание!";
                } catch (Exception $e) {
                    $error = "Ошибка при добавлении: " . $e->getMessage();
                }
                break;
                
            case 'update_schedule':
                $id = $_POST['id'];
                $branch = $_POST['branch'];
                $class_type = $_POST['class_type'];
                $day_of_week = $_POST['day_of_week'];
                $start_time = $_POST['start_time'];
                $class_name = $_POST['class_name'];
                $teacher = $_POST['teacher'];
                $status = $_POST['status'];
                
                try {
                    $stmt = $pdo->prepare("UPDATE schedule SET branch = ?, class_type = ?, day_of_week = ?, start_time = ?, class_name = ?, teacher = ?, status = ? WHERE id = ?");
                    $stmt->execute([$branch, $class_type, $day_of_week, $start_time, $class_name, $teacher, $status, $id]);
                    $success = "Расписание успешно обновлено!";
                } catch (Exception $e) {
                    $error = "Ошибка при обновлении: " . $e->getMessage();
                }
                break;
                
            case 'delete_schedule':
                $id = $_POST['id'];
                try {
                    $stmt = $pdo->prepare("DELETE FROM schedule WHERE id = ?");
                    $stmt->execute([$id]);
                    $success = "Занятие удалено из расписания!";
                } catch (Exception $e) {
                    $error = "Ошибка при удалении: " . $e->getMessage();
                }
                break;
                
            case 'export_schedule':
                // Экспорт расписания в JS файл
                $schedule_data = [];
                $stmt = $pdo->query("SELECT * FROM schedule WHERE status = 'active' ORDER BY branch, class_type, day_of_week, start_time");
                $all_schedule = $stmt->fetchAll();
                
                foreach ($all_schedule as $item) {
                    $branch_key = $item['branch'];
                    $class_key = $item['class_type'];
                    
                    if (!isset($schedule_data[$branch_key])) {
                        $schedule_data[$branch_key] = [];
                    }
                    if (!isset($schedule_data[$branch_key][$class_key])) {
                        $schedule_data[$branch_key][$class_key] = [];
                    }
                    
                    $schedule_data[$branch_key][$class_key][] = [
                        'day' => $item['day_of_week'],
                        'time' => $item['start_time'],
                        'name' => $item['class_name'],
                        'teacher' => $item['teacher']
                    ];
                }
                
                // Создаем JS файл
                $js_content = "// ========== assets/js/schedule.js - Расписание (Автоматически сгенерировано) ========== \n";
                $js_content .= "// Последнее обновление: " . date('Y-m-d H:i:s') . "\n\n";
                $js_content .= "const scheduleData = " . json_encode($schedule_data, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT) . ";\n\n";
                
                // Добавляем остальной код JS (функции)
                $js_content .= file_get_contents('../assets/js/schedule.js');
                
                // Сохраняем файл
                file_put_contents('../assets/js/schedule.js', $js_content);
                $success = "Расписание экспортировано в JS файл!";
                break;
        }
    }
}

// Получение расписания с фильтрами
$filter_branch = $_GET['branch'] ?? '';
$filter_class = $_GET['class_type'] ?? '';

$query = "SELECT * FROM schedule WHERE 1=1";
$params = [];

if ($filter_branch) {
    $query .= " AND branch = ?";
    $params[] = $filter_branch;
}

if ($filter_class) {
    $query .= " AND class_type = ?";
    $params[] = $filter_class;
}

$query .= " ORDER BY branch, class_type, FIELD(day_of_week, 'Понедельник', 'Вторник', 'Среда', 'Четверг', 'Пятница', 'Суббота', 'Воскресенье'), start_time";

$stmt = $pdo->prepare($query);
$stmt->execute($params);
$schedule_items = $stmt->fetchAll();

// Для редактирования
$edit_item = null;
if (isset($_GET['edit'])) {
    $stmt = $pdo->prepare("SELECT * FROM schedule WHERE id = ?");
    $stmt->execute([$_GET['edit']]);
    $edit_item = $stmt->fetch();
}
?>
