                                    <span class="badge <?= $item['status'] == 'active' ? 'badge-success' : 'badge-warning' ?>">
                                        <?= $item['status'] == 'active' ? 'Активное' : 'Неактивное' ?>
                                    </span>
                                </td>
                                <td class="actions-column">
                                    <a href="schedule.php?edit=<?= $item['id'] ?>" class="btn btn-small">✏️ Изменить</a>
                                    <form method="POST" style="display: inline;" 
                                          onsubmit="return confirm('Удалить это занятие из расписания?')">
                                        <input type="hidden" name="action" value="delete_schedule">
                                        <input type="hidden" name="id" value="<?= $item['id'] ?>">
                                        <button type="submit" class="btn btn-small btn-danger">🗑️ Удалить</button>
                                    </form>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>